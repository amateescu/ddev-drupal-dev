#!/usr/bin/env bash

#ddev-generated
## Description: Run PHPUnit tests
## Usage: phpunit [--db=mysql|sqlite|pgsql] [phpunit-args]
## Example: "ddev phpunit core/modules/field" or "ddev phpunit --db=sqlite core/modules/node"
## ExecRaw: true

set -e

DB=""

# Parse our flags, pass everything else through to PHPUnit.
args=()
for arg in "$@"; do
  case "$arg" in
    --db=*) DB="${arg#--db=}" ;;
    *) args+=("$arg") ;;
  esac
done

if ! command -v phpunit >/dev/null; then
  echo "phpunit is not in PATH in the web container. You probably forgot to 'ddev composer install'"
  exit 2
fi

# Clear stale webdriver sessions if Chrome is running.
curl -f -s http://chrome:4444/status 2>/dev/null | jq -r '.value.nodes[].slots[].session.sessionId' 2>/dev/null | while read -r session; do
  if [ "$session" != "null" ]; then
    curl -s -X DELETE "http://chrome:4444/session/$session" >/dev/null 2>&1
  fi
done

# Set the default SIMPLETEST_DB based on the project's database family.
if [ -z "${SIMPLETEST_DB:-}" ]; then
  case "$DDEV_DATABASE_FAMILY" in
    mysql)   export SIMPLETEST_DB="mysql://db:db@db/db" ;;
    postgres) export SIMPLETEST_DB="pgsql://db:db@db/db" ;;
  esac
fi

# Override the database URL if --db was specified.
if [ -n "$DB" ]; then
  case "$DB" in
    mysql)
      if [ "$DDEV_DATABASE_FAMILY" != "mysql" ]; then
        echo "Error: Your project's database is $DDEV_DATABASE_FAMILY, not MySQL."
        echo "Use --db=$DDEV_DATABASE_FAMILY or omit --db to use the default."
        exit 1
      fi
      export SIMPLETEST_DB="mysql://db:db@db/db"
      ;;
    sqlite) export SIMPLETEST_DB="sqlite://localhost/sites/default/files/db.sqlite" ;;
    pgsql)
      if [ "$DDEV_DATABASE_FAMILY" = "postgres" ]; then
        export SIMPLETEST_DB="pgsql://db:db@db/db"
      elif php -r "new PDO('pgsql:host=postgres;dbname=db', 'db', 'db');" 2>/dev/null; then
        export SIMPLETEST_DB="pgsql://db:db@postgres/db"
      else
        echo "Error: PostgreSQL is not available. Configure your project with"
        echo "postgres or add a separate postgres container."
        exit 1
      fi
      ;;
    *)
      echo "Error: Unknown database type '$DB'. Use mysql, sqlite, or pgsql."
      exit 1
      ;;
  esac
  echo "Using database: $DB"
fi

phpunit -c core "${args[@]}"
