{
    "_comment": "#ddev-generated",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": {
        "composer-git-installer": {
            "type": "path",
            "url": ".ddev/drupal-dev/composer-plugin"
        }
    },
    "require": {
        "drupal-dev/composer-git-installer": "*",
        "wikimedia/composer-merge-plugin": "^2",
        "mglaman/composer-drupal-lenient": "^1"
    },
    "extra": {
        "merge-plugin": {
            "include": ["composer.json"],
            "merge-extra": true,
            "merge-extra-deep": true,
            "merge-scripts": true
        },
        "drupal-lenient": {
            "allow-all": true
        }
    },
    "config": {
        "allow-plugins": true
    }
}
